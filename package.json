{
    "name": "createtree-office",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
        "server:dev": "npm run dev --prefix server",
        "client:dev": "npm run dev --prefix client",
        "db:push": "npm run db:push --prefix server",
        "db:generate": "npm run db:generate --prefix server"
    },
    "dependencies": {
        "concurrently": "^8.2.2"
    }
}